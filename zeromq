# Use legacy bundle on high-sierra
if [ "x${OSTYPE:6:1}" = "x1" ]; then
bottle="https://github.com/autobrew/bundler/releases/download/zeromq-4.3.4/zeromq-4.2.5-high_sierra.tar.xz"
else
bottle="https://github.com/autobrew/bundler/releases/download/zeromq-4.3.4/zeromq-4.3.4-universal.tar.xz"
MORELIBS="-lsodium"
fi

# Skip if disabled
if [ "$DISABLE_AUTOBREW" ]; then return 0; fi
echo "Using autobrew bundle: $(basename $bottle)"

# General setup
BREWDIR="$PWD/.deps"
mkdir -p $BREWDIR
curl -sSL $bottle -o libs.tar.xz
tar -xf libs.tar.xz --strip 1 -C $BREWDIR
cp ${BREWDIR}/lib/libzmq.a ${BREWDIR}/zeromq
cp ${BREWDIR}/lib/libsodium.a ${BREWDIR}/sodium
rm -f libs.tar.xz ${BREWDIR}/lib/*

# pkg-config --libs-only-l --static libzmq
PKG_LIBS="${BREWDIR}/zeromq ${BREWDIR}/sodium"
PKG_CFLAGS="-I$BREWDIR/include"

# Cleanup
echo "rm -Rf .deps" >> cleanup
chmod +x cleanup
