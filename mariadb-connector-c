# This seems to work even on big-sur
bottle="https://github.com/autobrew/bundler/releases/download/mariadb-connector-c-3.4.8/mariadb-connector-c-3.4.8-sonoma-universal.tar.xz"

# Skip if disabled
if [ "$DISABLE_AUTOBREW" ]; then return 0; fi
echo "Using autobrew bundle: $(basename $bottle)"

# Fix a linker warning on CRAN
if [ "m${MACOSX_DEPLOYMENT_TARGET:0:2}" = "m11" ]; then
MMACOS="-mmacosx-version-min=14.0"
fi

# General setup
BREWDIR="$PWD/.deps"
mkdir -p $BREWDIR
curl -sSL $bottle -o libs.tar.xz
tar -xf libs.tar.xz --strip 1 -C $BREWDIR && rm -f libs.tar.xz
PKG_CFLAGS="-I${BREWDIR}/include/mariadb"
PKG_LIBS="-L${BREWDIR}/lib -L${BREWDIR}/lib/mariadb -lmariadbclient -lssl -lcrypto -lzstd -llzma -llz4 -lz $MMACOS"

# NB: mariadb has libmariadbclient.a under subdirectory
for FILE in $(find . -type f -name '*.a'); do
  BASENAME=$(basename $FILE)
  LIBNAME=$(echo "${BASENAME%.*}" | cut -c4-)
  mv $FILE $BREWDIR/$LIBNAME
  PKG_LIBS=$(echo $PKG_LIBS | sed "s|-l$LIBNAME |../.deps/$LIBNAME |g")
done

# Fix _GSS_ linking error in CMD check
PKG_LIBS="$PKG_LIBS $(krb5-config --libs)"

# Cleanup
echo "rm -Rf .deps" >> cleanup
chmod +x cleanup
