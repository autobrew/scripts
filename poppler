if [ "x${OSTYPE:6:2}" = "x20" ]; then
bottle="https://github.com/autobrew/bundler/releases/download/poppler-23.04.0/poppler-23.04.0-universal.tar.xz"
else
# Works on at least MacOS 12(arm)
bottle="https://github.com/autobrew/bundler/releases/download/poppler-26.04.0/poppler-26.04.0-sonoma-universal.tar.xz"
fi

# Skip if disabled
if [ "$DISABLE_AUTOBREW" ]; then return 0; fi
echo "Using autobrew bundle: $(basename $bottle)"

# General setup
BREWDIR="$PWD/.deps"
mkdir -p $BREWDIR
curl -sSL $bottle -o libs.tar.xz
tar -xf libs.tar.xz --strip 1 -C $BREWDIR
rm -f libs.tar.xz
rm -f $BREWDIR/lib/libpng.a

# Suppess linker warnings on CRAN
if [ "m${MACOSX_DEPLOYMENT_TARGET:0:2}" = "m11" ]; then
MMACOS="-mmacosx-version-min=14.0"
fi

# Hardcoded flags
PKG_CFLAGS="-DBUNDLE_POPPLER_DATA -I${BREWDIR}/include/poppler/cpp -I${BREWDIR}/include/poppler"
PKG_LIBS="-L${BREWDIR}/lib -lpoppler-cpp -lpoppler -lcairo -lpixman-1 -lfontconfig -lexpat -lfreetype -lbz2 -lpng16 -llzo2 -llcms2 -lopenjp2 -ltiff -lturbojpeg -lzstd -lz -lm -liconv -lpthread $MMACOS"

# Ship poppler training data
mkdir -p inst/share
cp -Rf $BREWDIR/share/poppler inst/share/

# Prevent CRAN builder from linking against old libs in /usr/local/lib
for FILE in $BREWDIR/lib/*.a; do
  BASENAME=$(basename $FILE)
  LIBNAME=$(echo "${BASENAME%.*}" | cut -c4-)
  mv $FILE $BREWDIR/$LIBNAME
  PKG_LIBS=$(echo $PKG_LIBS | sed "s|-l$LIBNAME |../.deps/$LIBNAME |g")
done

# Cleanup
echo "rm -Rf .deps" >> cleanup
chmod +x cleanup

# Temporary fix for CRAN warnings
if [ $(arch | grep arm) ]; then
sed -i '' 's/CXX11/CXX14/g' src/Makevars.in
fi